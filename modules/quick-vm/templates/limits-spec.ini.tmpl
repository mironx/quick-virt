# =============================================================================
# quick-virt — VM resource limits specification
# =============================================================================
# This file is generated automatically by the quick-virt Terraform module.
# Do NOT edit by hand — your changes will be overwritten on next 'terraform apply'.
#
# Purpose: declarative record of CPU and I/O throttling configured on a VM.
# Intended consumers:
#   - `bash qv-limits.apply.<vm-name>.sh`  — apply all limits live via virsh
#   - `bash qv-limits.clear.<vm-name>.sh`  — clear every CPU/IO limit
#   - Python / awk scripts                 — read and re-apply selectively
#
# File layout: INI with hierarchical section names (dot-separated).
# =============================================================================

[meta]
# VM name as registered in libvirt (matches `virsh list --all`).
vm_name      = ${vm_name}

# ISO-8601 UTC timestamp when this file was generated by terraform apply.
generated_at = ${generated_at}

# quick-virt version that produced this file (from Taskfile or install.sh).
quick_virt_version = ${quick_virt_version}


[apply]
# If true, limits are baked into the libvirt domain XML (via XSLT transform).
# Effect: persistent — activate on next domain (re)boot.
enable_config = ${enable_config}

# If true, sidecar files (.ini + .sh) are generated next to this file.
# Effect: ephemeral — apply on the running VM via `virsh ... --live` without
#         reboot. Settings revert to the domain XML values after VM restart.
enable_live   = ${enable_live}


%{ if cpu_limit != null ~}
[cpu]
# -----------------------------------------------------------------------------
# CPU bandwidth limit via Linux CFS (Completely Fair Scheduler) cgroups.
# The guest OS still sees `vcpu` cores but can only consume `quota_us` worth
# of CPU time within each `period_us` window (across all vCPUs combined).
#
# Selection rule (used by qv-limits.apply.*.sh):
#   1. If BOTH `period_us` AND `quota_us` are uncommented    → RAW mode (wins).
#   2. Else if `percent` is uncommented                      → PERCENT mode,
#      script computes: quota_us = vcpu × period_us × percent / 100
#                       (period_us defaults to 100000 when not set).
#   3. Else                                                  → CPU limit skipped.
# Edit below to switch modes — comment/uncomment lines and re-run the apply script.
# -----------------------------------------------------------------------------

# VM vCPU count — needed by the apply script for percent → quota conversion.
vcpu      = ${vcpu}

# High-level: percentage of the total allocated CPU capacity the VM can use.
#   percent = 100 → full allocation (no limit)
#   percent =  25 with vcpu=4 → effective ~1 core of 4
%{ if cpu_limit._user_percent ~}
percent   = ${cpu_limit.percent}
%{ else ~}
# percent   =
%{ endif ~}

# Low-level CFS parameters (microseconds). Uncomment BOTH to force RAW mode
# (overrides `percent` above). Typical period = 100000 (100 ms).
%{ if cpu_limit._user_period_us ~}
period_us = ${cpu_limit.period_us}
%{ else ~}
# period_us = ${cpu_limit.period_us}
%{ endif ~}
%{ if cpu_limit._user_quota_us ~}
quota_us  = ${cpu_limit.quota_us}
%{ else ~}
# quota_us  = ${cpu_limit.quota_us}
%{ endif ~}

# Relative weight across VMs (soft priority, NOT a hard limit).
# Default libvirt: 1024. Higher = more CPU time under contention.
%{ if cpu_limit.shares != null ~}
shares    = ${cpu_limit.shares}
%{ else ~}
# shares    =
%{ endif ~}
%{ endif ~}


%{ for dev, throttle in io_limits ~}
[io.${dev}]
# -----------------------------------------------------------------------------
# Block I/O throttle for disk '${dev}'.
# Enforced by QEMU's internal block-throttling (independent of host I/O scheduler).
# Zero / empty = no limit on that dimension.
#
# Byte values below are already normalised to raw BYTES per second by the
# Terraform module. In the vm_profile source you can write them with a unit
# multiplier and the module will convert — e.g.
#
#   io = {
#     vda = {
#       bytes_unit      = "MB"   # default unit for this disk
#       read_bytes_sec  = 10     # → 10 MB/s  = 10485760 bytes/s
#       write_bytes_sec = 5      # →  5 MB/s  =  5242880 bytes/s
#       write_bytes_sec_unit = "KB"  # per-field override: →  5 KB/s
#     }
#   }
#
# Units: "B" (=1), "KB" (=1024), "MB" (=1048576), "GB" (=1073741824).
# Ready-to-copy reference table (raw bytes):
#   -    512 KB/s =       524288
#   -      1 MB/s =      1048576
#   -      5 MB/s =      5242880
#   -     10 MB/s =     10485760
#   -     25 MB/s =     26214400
#   -     50 MB/s =     52428800
#   -    100 MB/s =    104857600
#   -    250 MB/s =    268435456
#   -    500 MB/s =    524288000
#   -      1 GB/s =   1073741824
#   -      2 GB/s =   2147483648
# Quick math: MB/s = bytes / 1048576   |   bytes = MB/s * 1048576
# -----------------------------------------------------------------------------

# Sustained bandwidth (bytes per second).
%{ if throttle.read_bytes_sec != null ~}
read_bytes_sec  = ${throttle.read_bytes_sec}
%{ endif ~}
%{ if throttle.write_bytes_sec != null ~}
write_bytes_sec = ${throttle.write_bytes_sec}
%{ endif ~}

# Sustained I/O operations per second (typical: 100 – 100000).
# Reference: HDD ~100–200 IOPS, SATA SSD ~10k-50k, NVMe ~100k-1M.
%{ if throttle.read_iops_sec != null ~}
read_iops_sec   = ${throttle.read_iops_sec}
%{ endif ~}
%{ if throttle.write_iops_sec != null ~}
write_iops_sec  = ${throttle.write_iops_sec}
%{ endif ~}

%{ if (throttle.read_bytes_sec_max != null || throttle.write_bytes_sec_max != null || throttle.read_iops_sec_max != null || throttle.write_iops_sec_max != null) ~}

[io.${dev}.burst]
# Short-term burst allowance above the baseline — modelled as a token bucket.
# The VM may exceed baseline up to `*_max` for `*_max_length` seconds when it
# has been idle; then it returns to the baseline rate.
#
# Same byte unit conversions as [io.${dev}] above. Typical burst profile:
#   baseline:  5 MB/s (5242880)      burst_max:  20 MB/s (20971520)
#   baseline: 10 MB/s (10485760)     burst_max:  50 MB/s (52428800)
#   baseline: 50 MB/s (52428800)     burst_max: 200 MB/s (209715200)
# `*_max_length` is in SECONDS — how long the burst can be sustained before
# falling back to baseline. Typical: 1 – 30 seconds.
%{ if throttle.read_bytes_sec_max != null ~}
read_bytes_sec_max         = ${throttle.read_bytes_sec_max}
%{ endif ~}
%{ if throttle.read_bytes_sec_max_length != null ~}
read_bytes_sec_max_length  = ${throttle.read_bytes_sec_max_length}
%{ endif ~}
%{ if throttle.write_bytes_sec_max != null ~}
write_bytes_sec_max        = ${throttle.write_bytes_sec_max}
%{ endif ~}
%{ if throttle.write_bytes_sec_max_length != null ~}
write_bytes_sec_max_length = ${throttle.write_bytes_sec_max_length}
%{ endif ~}
%{ if throttle.read_iops_sec_max != null ~}
read_iops_sec_max          = ${throttle.read_iops_sec_max}
%{ endif ~}
%{ if throttle.read_iops_sec_max_length != null ~}
read_iops_sec_max_length   = ${throttle.read_iops_sec_max_length}
%{ endif ~}
%{ if throttle.write_iops_sec_max != null ~}
write_iops_sec_max         = ${throttle.write_iops_sec_max}
%{ endif ~}
%{ if throttle.write_iops_sec_max_length != null ~}
write_iops_sec_max_length  = ${throttle.write_iops_sec_max_length}
%{ endif ~}
%{ endif ~}

%{ endfor ~}

%{ for iface, n in net_limits ~}
[net.${iface}]
# -----------------------------------------------------------------------------
# Network bandwidth throttle for interface index ${iface} (networks[${iface}]).
# Libvirt units: RATES are in KiB/s, BURST is in KiB (binary — 1 KiB = 1024 B).
# The module accepts rate_unit (KB/MB/GB) in vm_profile and normalises here.
#
# Ready-to-copy rate reference (values in KiB/s, i.e. what libvirt sees):
#   -   128 KiB/s  =       128
#   -     1 MiB/s  =      1024
#   -    10 MiB/s  =     10240
#   -   100 MiB/s  =    102400
#   -     1 GiB/s  =   1048576
# -----------------------------------------------------------------------------

%{ if n.inbound != null ~}
[net.${iface}.inbound]
# Traffic going INTO the VM (download).
%{ if n.inbound.average != null ~}
average = ${n.inbound.average}
%{ endif ~}
%{ if n.inbound.peak != null ~}
peak    = ${n.inbound.peak}
%{ endif ~}
%{ if n.inbound.burst != null ~}
burst   = ${n.inbound.burst}
%{ endif ~}
%{ if n.inbound.floor != null ~}
floor   = ${n.inbound.floor}
%{ endif ~}
%{ endif ~}

%{ if n.outbound != null ~}
[net.${iface}.outbound]
# Traffic leaving the VM (upload). `floor` is supported here for QoS-capable networks.
%{ if n.outbound.average != null ~}
average = ${n.outbound.average}
%{ endif ~}
%{ if n.outbound.peak != null ~}
peak    = ${n.outbound.peak}
%{ endif ~}
%{ if n.outbound.burst != null ~}
burst   = ${n.outbound.burst}
%{ endif ~}
%{ if n.outbound.floor != null ~}
floor   = ${n.outbound.floor}
%{ endif ~}
%{ endif ~}

%{ endfor ~}

# =============================================================================
# End of spec.
# =============================================================================