#!/bin/bash
# =============================================================================
# quick-virt — apply resource limits to every VM in the '${set_name}' set
# =============================================================================
# Auto-generated by the quick-vms Terraform module.
# Runs the per-VM apply script (qv-limits.apply.<vm>.sh) for every node in the set.
#
# Usage:
#   bash qv-limits.apply-all.${set_name}.sh
#
# Skips missing per-VM scripts with a warning (handy when a VM was destroyed
# ad-hoc but not yet reflected in Terraform state).
# =============================================================================
set -u

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

VMS=(
%{ for name in vm_names ~}
    "${name}"
%{ endfor ~}
)

echo "[*] Applying limits to ${length(vm_names)} VM(s) in set '${set_name}'"

fail=0
for vm in "$${VMS[@]}"; do
    script="$SCRIPT_DIR/qv-limits.apply.$vm.sh"
    if [ ! -f "$script" ]; then
        echo "[warn] $vm: per-VM script not found ($script) — skipping"
        continue
    fi
    echo "--- $vm ---"
    if ! bash "$script" "$vm"; then
        echo "[error] $vm: apply failed"
        fail=$((fail + 1))
    fi
done

if [ "$fail" -gt 0 ]; then
    echo "[error] $fail VM(s) failed in set '${set_name}'" >&2
    exit 1
fi
echo "[ok] Limits applied to set '${set_name}'"